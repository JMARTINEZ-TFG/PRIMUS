# Copiar a .env (local) o cargar en Vercel → Project Settings → Environment Variables.
# NO commitear el .env con valores reales.

# Base de datos PostgreSQL (Neon)
DATABASE_URL=

# Secreto para firmar los JWT de sesión
JWT_SECRET=

# API key del servicio de OCR
OCR_API_KEY=

# API key de Resend (envío de emails)
RESEND_API_KEY=

# URL pública de la app (ej. https://primus.vercel.app)
APP_URL=

# Integración Prometeo (datos bancarios)
PROMETEO_API_KEY=
PROMETEO_ENV=
PROMETEO_MOCK=
